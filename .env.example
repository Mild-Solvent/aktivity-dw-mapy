# Local Supabase (Docker) — run "npm run db:start" then "npm run db:status"
VITE_SUPABASE_URL=http://127.0.0.1:55321
VITE_SUPABASE_PUBLISHABLE_KEY=<anon key from "npm run db:status">

# Comma-separated admin emails (must match seed in migration 20260615000100)
VITE_ADMIN_EMAILS=your-admin@example.com
